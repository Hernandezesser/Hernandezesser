import requests
import pandas as pd
from datetime import datetime, timedelta
import os

def download_and_save_data(api_url, bearer_token, directory_path, file_prefix, include_dates=False):
    headers = {
        "Authorization": f"Bearer {bearer_token}",
        "Content-Type": "application/json",
    }

    params = {}
    today = datetime.now()

    # Solo para ventas: siempre traer mes anterior completo + lo que va del mes actual
    if include_dates:
        # Último día del mes anterior
        last_day_prev_month = today.replace(day=1) - timedelta(days=1)
        # Primer día del mes anterior
        first_day_prev_month = last_day_prev_month.replace(day=1)
        # Hoy (para incluir lo que va del mes actual)
        end_date = today

        start_date = first_day_prev_month
        end_date_final = end_date

        formatted_start_date = start_date.strftime("%Y%m%d")
        formatted_end_date = end_date_final.strftime("%Y%m%d")

        # Construimos la URL con los parámetros
        api_url_with_dates = f"{api_url}?inicio={formatted_start_date}&termino={formatted_end_date}"
        
        print(f"Descargando ventas desde {formatted_start_date} hasta {formatted_end_date}")
    else:
        api_url_with_dates = api_url

    try:
        response = requests.get(api_url_with_dates, headers=headers, timeout=60)

        if response.status_code == 200:
            try:
                data = response.json()
                if not data:
                    print(f"Advertencia: No se recibieron datos para {file_prefix}")
                    return

                df = pd.DataFrame(data)
                
                # Crear carpeta si no existe
                os.makedirs(directory_path, exist_ok=True)

                # Nombre del archivo con fecha de ejecución
                current_date = today.strftime("%Y-%m-%d")
                excel_filename = f"{file_prefix}_{current_date}.xlsx"
                file_path = os.path.join(directory_path, excel_filename)

                df.to_excel(file_path, index=False)
                print(f"Datos de {file_prefix} guardados en: {file_path} ({len(df)} filas)")

            except ValueError as e:
                print(f"Error al procesar JSON para {file_prefix}: {e}")
            except Exception as e:
                print(f"Error al guardar Excel para {file_prefix}: {e}")
        else:
            print(f"Error API {file_prefix}: {response.status_code} - {response.text}")

    except requests.exceptions.RequestException as e:
        print(f"Error de conexión para {file_prefix}: {e}")

